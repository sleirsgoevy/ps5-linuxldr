diff --git a/arch/x86/mm/extable.c b/arch/x86/mm/extable.c
index 6b9ff1c6c..a1950ef6f 100644
--- a/arch/x86/mm/extable.c
+++ b/arch/x86/mm/extable.c
@@ -12,6 +12,7 @@
 #include <asm/kdebug.h>
 #include <asm/insn-eval.h>
 #include <asm/sgx.h>
+#include <asm/setup.h>
 
 static inline unsigned long *pt_regs_nr(struct pt_regs *regs, int nr)
 {
@@ -316,6 +317,53 @@ int fixup_exception(struct pt_regs *regs, int trapnr, unsigned long error_code,
 	}
 #endif
 
+	if (unlikely(boot_params.hdr.hardware_subarch == X86_SUBARCH_PS5) && trapnr == X86_TRAP_SX) {
+		switch ((int32_t)error_code) {
+		case -7:
+		case -11: //XXX: what's the difference?
+		{
+			//this might be an MSR trapped by the hypervisor
+			//or this could be an I/O operation trapped by the same hypervisor
+			//in either case, the saved RIP is AFTER the instruction
+			uint8_t* code = (uint8_t*)regs->ip;
+			if (code[-2] == 0x0f && (code[-1] == 0x30 || code[-1] == 0x32)) { //rdmsr or wrmsr
+				//inject a fake #GP
+				trapnr = X86_TRAP_GP;
+				regs->ip -= 2;
+				regs->orig_ax = error_code = 0;
+				break;
+			} else { //assuming this is an I/O instruction
+				int possible_1byte = (code[-1] >= 0xec && code[-1] <= 0xef);
+				int possible_2byte = (code[-2] >= 0xe4 && code[-2] <= 0xe7);
+				if(!(possible_1byte ^ possible_2byte))
+					break; //unknown instruction, no idea how to handle. let the kernel just print a stack trace
+				if (possible_1byte)
+					code--;
+				else
+					code -= 2;
+				//don't even try to handle the 0x66 prefix. gcc always treats half-register writes as full-width anyway
+				switch (code[0]) {
+				//out instructions: simply discard
+				case 0xe6:
+				case 0xe7:
+				case 0xee:
+				case 0xef:
+					return 1;
+				//in instructions: write 0 to rax to pretend that *something* has been read
+				case 0xe4:
+				case 0xe5:
+				case 0xec:
+				case 0xed:
+					regs->ax = 0;
+					return 1;
+				//everything else: we have no idea what that is, leave the exception as is
+                default:
+				}
+			}
+			break;
+		}
+		}
+	}
 	e = search_exception_tables(regs->ip);
 	if (!e)
 		return 0;
