diff --git a/drivers/tty/serial/titania.c b/drivers/tty/serial/titania.c
new file mode 100644
index 000000000..b3fc4dcaa
--- /dev/null
+++ b/drivers/tty/serial/titania.c
@@ -0,0 +1,46 @@
+#include <linux/console.h>
+#include <linux/serial_core.h>
+#include <linux/platform_device.h>
+#include <linux/irqdomain.h>
+#include <linux/irq.h>
+#include <linux/tty_flip.h>
+#include <asm/irqdomain.h>
+#include <asm/hw_irq.h>
+#include <asm/io.h>
+#include <asm/setup.h>
+
+static void titania_early_putchar(void __iomem *registers, char c)
+{
+	while ((readl(registers+12) & 0x800));
+	writel(c, registers+4);
+}
+
+static void titania_early_write(struct console *con, const char *s, unsigned int n)
+{
+	void __iomem *registers = con->data;
+	for (unsigned int i = 0; i < n; ++i) {
+		if (s[i] == '\n')
+			titania_early_putchar(registers, '\r');
+		titania_early_putchar(registers, s[i]);
+	}
+}
+
+static int titania_early_read(struct console *con, char *s, unsigned int n)
+{
+	void __iomem *registers = (void __iomem*)con->data;
+	unsigned int i = 0;
+
+	while (i < n && (readl(registers+12) & 0x10))
+		s[i++] = readl(registers+0);
+
+	return i;
+}
+
+static int __init titania_early_console_setup(struct earlycon_device *device, const char *opt)
+{
+	device->con->data = (void*)early_ioremap(0xc1010100, 16);
+	device->con->write = titania_early_write;
+	device->con->read = titania_early_read;
+	return 0;
+}
+EARLYCON_DECLARE(titania, titania_early_console_setup);
