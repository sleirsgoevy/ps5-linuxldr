diff --git a/arch/x86/boot/compressed/misc.c b/arch/x86/boot/compressed/misc.c
index 0f41ca0e5..04e9d4d38 100644
--- a/arch/x86/boot/compressed/misc.c
+++ b/arch/x86/boot/compressed/misc.c
@@ -115,6 +115,16 @@ static void serial_putchar(int ch)
 	outb(ch, early_serial_base + TXR);
 }
 
+static void ps5_putchar(uint8_t ch)
+{
+	volatile uint32_t* titania_uart = (volatile uint32_t*)0xc1010100;
+	if (ch == '\n')
+		ps5_putchar('\r');
+	while ((titania_uart[3] & 0x800))
+		cpu_relax();
+	titania_uart[1] = ch;
+}
+
 void __putstr(const char *s)
 {
 	int x, y, pos;
@@ -129,6 +139,12 @@ void __putstr(const char *s)
 		}
 	}
 
+	if (boot_params_ptr->hdr.hardware_subarch == X86_SUBARCH_PS5) {
+		const char *str = s;
+		while (*str)
+			ps5_putchar(*str++);
+	}
+
 	if (lines == 0 || cols == 0)
 		return;
 
